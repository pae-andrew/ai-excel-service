ANTHROPIC_API_KEY=sk-ant-...
ALLOWED_ORIGIN=http://localhost:3000
MODEL=claude-opus-4-8

# Опционально — экспорт результата в Google Sheets. Без них кнопка
# "В Google Sheets" просто отдаёт понятную ошибку 501.
# Завести: console.cloud.google.com -> OAuth consent screen + Credentials ->
# OAuth client ID (Web application) -> Authorized redirect URI = значение ниже.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/google/callback
